# ============================================================
# Agent Hub 环境变量配置模板
# 使用方法：复制为 .env，填入你的真实 Key
#   cp .env.example .env
# ============================================================

# ── 基础配置 ──────────────────────────────────────────────
APP_NAME=Agent Hub
APP_ENV=dev
API_PREFIX=/api/v1

# ── LLM 配置 ─────────────────────────────────────────────
# litellm 原生支持以下厂商前缀，选择你要用的一种即可：
#
# 【DeepSeek】（推荐，性价比高）
CREWAI_LLM=deepseek/deepseek-chat
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# 【通义千问 Qwen / DashScope】
# CREWAI_LLM=dashscope/qwen-plus
# DASHSCOPE_API_KEY=your-dashscope-api-key-here
#
# 【OpenAI】
# CREWAI_LLM=openai/gpt-4o-mini
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# OPENAI_API_BASE=https://api.openai.com/v1
#
# 【OpenAI 兼容中转（one-api / new-api）】
# CREWAI_LLM=openai/gpt-4o-mini
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# OPENAI_API_BASE=https://your-gateway.com/v1

# ── 可选：Qwen 国际区 ────────────────────────────────────
# DASHSCOPE_API_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
